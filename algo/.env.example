# Copy to .env and fill in — NEVER commit .env

# Wallet (required for live orders)
PRIVATE_KEY=0x...

# Optional: reuse derived API creds (skip re-derive each start)
# CLOB_API_KEY=
# CLOB_SECRET=
# CLOB_PASS_PHRASE=

# Polymarket proxy wallet (if you trade via Polymarket UI deposit address)
# SIGNATURE_TYPE=1
# FUNDER_ADDRESS=0x...

# 0 = paper only (logs order, no submit). 1 = real orders.
ALGO_LIVE=0

# Strategy — 5m BTC up/down only
ALGO_LIMIT_PRICE=0.71
ALGO_ORDER_SIZE=1
ALGO_MARKET_SPAN_SEC=300
ALGO_SLUG_PREFIX=btc-updown-5m
